# ================================
# GEMINI AI CONFIGURATION
# ================================
# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ================================
# DATABASE CONFIGURATION
# ================================
# SQLite: sqlite:///./kisansethu.db
# PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./kisansethu.db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ================================
# JWT & AUTHENTICATION
# ================================
# IMPORTANT: Change this to a secure random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BCRYPT_ROUNDS=12

# ================================
# APP CONFIGURATION
# ================================
APP_NAME=Kisan Sethu API
APP_VERSION=0.1.0
ENVIRONMENT=development

# ================================
# CORS & SERVER CONFIGURATION
# ================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://192.168.1.65:3000
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.65

# ================================
# FILE UPLOAD CONFIGURATION
# ================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ================================
# API ENDPOINTS CONFIGURATION
# ================================
API_PREFIX=/api
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# ================================
# LOGGING CONFIGURATION
# ================================
LOG_LEVEL=INFO

# ================================
# PRODUCTION SETTINGS
# ================================
# DEBUG=false
# WORKERS=4
